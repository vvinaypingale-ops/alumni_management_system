<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>AlumniManagementSystem</display-name>

    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

    <!-- 
      Note: We have used @WebServlet annotations in the Servlet classes (Servlet 3.0+).
      However, if you are using an older server or prefer XML-based mapping, 
      you would define them here like this:
    -->
    
    <!-- Servlet mappings removed because they are already defined using @WebServlet annotations in Java classes -->

    <!-- Session Configuration -->
    <session-config>
        <session-timeout>30</session-timeout> <!-- 30 minutes -->
    </session-config>

</web-app>
